<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg">
        <div class="hero-glow hero-glow-1"></div>
        <div class="hero-glow hero-glow-2"></div>
        <div class="hero-particles" id="heroParticles"></div>
    </div>
    <div class="hero-content">
        <div class="hero-badge">✦ AI-Powered Skincare</div>
        <h1 class="hero-title">
            Discover Your
            <span class="hero-gradient">Perfect Glow</span>
        </h1>
        <p class="hero-subtitle">Personalized skincare recommendations powered by AI. Take our skin quiz, get matched with products designed for <em>your</em> unique skin type.</p>
        <div class="hero-actions">
            <% if (user) { %>
                <a href="/quiz" class="btn btn-primary btn-lg"><i class="fas fa-magic"></i> Take Skin Quiz</a>
                <a href="/products?recommended=true" class="btn btn-glass btn-lg"><i class="fas fa-sparkles"></i> Recommended For You</a>
            <% } else { %>
                <a href="/auth/register" class="btn btn-primary btn-lg"><i class="fas fa-user-plus"></i> Get Started Free</a>
                <a href="/products" class="btn btn-glass btn-lg"><i class="fas fa-spa"></i> Explore Products</a>
            <% } %>
        </div>
        <div class="hero-stats">
            <div class="hero-stat">
                <span class="stat-number">155+</span>
                <span class="stat-label">Products</span>
            </div>
            <div class="hero-stat">
                <span class="stat-number">20</span>
                <span class="stat-label">Brands</span>
            </div>
            <div class="hero-stat">
                <span class="stat-number">5</span>
                <span class="stat-label">Skin Types</span>
            </div>
            <div class="hero-stat">
                <span class="stat-number">AI</span>
                <span class="stat-label">Powered</span>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="section how-it-works">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">How It Works</span>
            <h2 class="section-title">Your Skincare Journey</h2>
            <p class="section-subtitle">Three simple steps to radiant, personalized skincare</p>
        </div>
        <div class="steps-grid">
            <div class="step-card" data-aos="fade-up">
                <div class="step-number">01</div>
                <div class="step-icon"><i class="fas fa-clipboard-list"></i></div>
                <h3>Take the Quiz</h3>
                <p>Answer 10 quick questions about your skin. Our algorithm determines your exact skin type with up to 99% accuracy.</p>
            </div>
            <div class="step-card" data-aos="fade-up" data-delay="200">
                <div class="step-number">02</div>
                <div class="step-icon"><i class="fas fa-robot"></i></div>
                <h3>AI Analysis</h3>
                <p>Chat with our AI expert for detailed skincare advice, generate personalized routines, or upload a photo for skin analysis.</p>
            </div>
            <div class="step-card" data-aos="fade-up" data-delay="400">
                <div class="step-number">03</div>
                <div class="step-icon"><i class="fas fa-shopping-bag"></i></div>
                <h3>Shop & Glow</h3>
                <p>Browse 155+ curated products matched to your skin type. Order, track, and review — all in one place.</p>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="section featured-section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Curated for You</span>
            <h2 class="section-title">Featured Products</h2>
            <p class="section-subtitle">Handpicked skincare essentials from top brands</p>
        </div>
        <div class="products-grid">
            <% featured.forEach(product => { %>
                <a href="/products/<%= product.Product_id %>" class="product-card">
                    <div class="product-image">
                        <img src="/product-image/<%= product.Product_id %>" alt="<%= product.Product_name %>" loading="lazy">
                        <span class="product-badge skin-<%= product.P_Skin_type.toLowerCase() %>"><%= product.P_Skin_type %></span>
                    </div>
                    <div class="product-info">
                        <span class="product-brand"><%= product.Brand_name %></span>
                        <h3 class="product-name"><%= product.Product_name %></h3>
                        <div class="product-meta">
                            <span class="product-category"><i class="fas fa-tag"></i> <%= product.Category %></span>
                            <span class="product-price">₹<%= product.Price.toLocaleString('en-IN') %></span>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
        <div class="section-cta">
            <a href="/products" class="btn btn-primary"><i class="fas fa-th"></i> View All Products</a>
        </div>
    </div>
</section>

<!-- Skin Types Section -->
<section class="section skin-types-section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Know Your Skin</span>
            <h2 class="section-title">We Cover All Skin Types</h2>
        </div>
        <div class="skin-types-grid">
            <div class="skin-type-card skin-oily-card">
                <div class="skin-type-icon">💧</div>
                <h3>Oily</h3>
                <p>Excess sebum, enlarged pores, shine-prone</p>
            </div>
            <div class="skin-type-card skin-dry-card">
                <div class="skin-type-icon">🏜️</div>
                <h3>Dry</h3>
                <p>Tight feeling, flaky patches, fine lines</p>
            </div>
            <div class="skin-type-card skin-combination-card">
                <div class="skin-type-icon">⚖️</div>
                <h3>Combination</h3>
                <p>Oily T-zone, dry or normal cheeks</p>
            </div>
            <div class="skin-type-card skin-sensitive-card">
                <div class="skin-type-icon">🌸</div>
                <h3>Sensitive</h3>
                <p>Easily irritated, redness-prone, reactive</p>
            </div>
            <div class="skin-type-card skin-normal-card">
                <div class="skin-type-icon">✨</div>
                <h3>Normal</h3>
                <p>Well-balanced, minimal concerns, even texture</p>
            </div>
        </div>
    </div>
</section>

<!-- Brands Section -->
<section class="section brands-section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Trusted Partners</span>
            <h2 class="section-title">Top Skincare Brands</h2>
        </div>
        <div class="brands-scroll">
            <% brands.forEach(brand => { %>
                <a href="/products?brand=<%= brand.Brand_id %>" class="brand-pill">
                    <span class="brand-name"><%= brand.Brand_name %></span>
                    <span class="brand-country"><%= brand.Country %></span>
                </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section cta-section">
    <div class="cta-bg">
        <div class="cta-glow"></div>
    </div>
    <div class="container">
        <div class="cta-content">
            <h2>Ready to Transform Your Skin?</h2>
            <p>Join thousands who've discovered their perfect skincare routine with Luminar's AI-powered technology.</p>
            <% if (!user) { %>
                <a href="/auth/register" class="btn btn-primary btn-lg"><i class="fas fa-arrow-right"></i> Start Your Journey</a>
            <% } else { %>
                <a href="/assistant" class="btn btn-primary btn-lg"><i class="fas fa-robot"></i> Chat with AI Assistant</a>
            <% } %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
